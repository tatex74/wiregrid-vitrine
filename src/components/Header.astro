---
import Logo from './Logo.astro';
import { t, getAlternateUrl, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const alternateLang = lang === 'fr' ? 'en' : 'fr';
const alternateUrl = getAlternateUrl(Astro.url, alternateLang);
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/90 backdrop-blur-sm">
  <div class="mx-auto max-w-6xl flex items-center justify-between px-6 py-4">
    <a href={`/${lang}/`} class="flex items-center gap-2 text-brand hover:text-brand-hover transition-colors">
      <Logo class="w-6 h-6" />
      <span class="font-semibold text-lg tracking-tight text-text">wiregrid</span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm">
      <a href={`/${lang}/#features`} class="text-muted hover:text-text transition-colors">{t(lang, 'nav.features')}</a>
      <a href={`/${lang}/#pricing`} class="text-muted hover:text-text transition-colors">{t(lang, 'nav.pricing')}</a>
      <a href={alternateUrl} class="text-muted hover:text-text transition-colors uppercase font-mono text-xs border border-border px-2 py-1 rounded-sm">
        {alternateLang}
      </a>
      <a href="https://demo.wiregrid.fr" target="_blank" rel="noopener" class="btn btn-primary">
        {t(lang, 'nav.demo')}
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden text-muted hover:text-text" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-border px-6 py-4 flex flex-col gap-4 text-sm bg-bg">
    <a href={`/${lang}/#features`} class="text-muted hover:text-text">{t(lang, 'nav.features')}</a>
    <a href={`/${lang}/#pricing`} class="text-muted hover:text-text">{t(lang, 'nav.pricing')}</a>
    <a href={alternateUrl} class="text-muted hover:text-text uppercase font-mono text-xs">{alternateLang}</a>
    <a href="https://demo.wiregrid.fr" target="_blank" rel="noopener" class="btn btn-primary text-center">
      {t(lang, 'nav.demo')}
    </a>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
