---
import Logo from './Logo.astro';
import { t, getAlternateUrl, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const alternateLang: Lang = lang === 'fr' ? 'en' : 'fr';
const alternateLangLabel = alternateLang === 'fr' ? 'Français' : 'English';
const alternateUrl = getAlternateUrl(Astro.url, alternateLang);
const switchLanguageLabel = t(lang, 'a11y.switch_language').replace('{lang}', alternateLangLabel);
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/85 backdrop-blur-md">
  <div class="mx-auto max-w-6xl flex items-center justify-between px-6 h-14">
    <a
      href={`/${lang}/`}
      class="flex items-center gap-2 text-brand hover:text-brand-hover transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand rounded-sm"
      aria-label="Wiregrid"
    >
      <Logo class="w-5 h-5" />
      <span class="font-semibold text-[15px] tracking-[-0.01em] text-text">wiregrid</span>
    </a>

    <nav class="hidden md:flex items-center gap-7" aria-label="Primary">
      <a href={`/${lang}/#comparison`} class="nav-link">{t(lang, 'nav.comparison')}</a>
      <a href={`/${lang}/#features`} class="nav-link">{t(lang, 'nav.features')}</a>
      <a href={`/${lang}/#pricing`} class="nav-link">{t(lang, 'nav.pricing')}</a>
      <a href={`/${lang}/#faq`} class="nav-link">{t(lang, 'nav.faq')}</a>
      <span class="w-px h-4 bg-border" aria-hidden="true"></span>
      <a
        href={alternateUrl}
        hreflang={alternateLang}
        lang={alternateLang}
        aria-label={switchLanguageLabel}
        class="text-muted hover:text-text transition-colors uppercase font-mono text-[11px] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
      >
        {alternateLang}
      </a>
      <a href="https://demo.wiregrid.fr" target="_blank" rel="noopener" class="btn btn-primary">
        {t(lang, 'nav.demo')}
      </a>
    </nav>

    <button
      id="mobile-menu-btn"
      type="button"
      class="md:hidden text-muted hover:text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand rounded-sm"
      aria-label={t(lang, 'a11y.open_menu')}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="square" d="M4 7h16M4 12h16M4 17h16"/>
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-border px-6 py-4 flex-col gap-3 text-sm bg-bg"
    aria-label="Mobile primary"
  >
    <a href={`/${lang}/#comparison`} class="nav-link">{t(lang, 'nav.comparison')}</a>
    <a href={`/${lang}/#features`} class="nav-link">{t(lang, 'nav.features')}</a>
    <a href={`/${lang}/#pricing`} class="nav-link">{t(lang, 'nav.pricing')}</a>
    <a href={`/${lang}/#faq`} class="nav-link">{t(lang, 'nav.faq')}</a>
    <a
      href={alternateUrl}
      hreflang={alternateLang}
      lang={alternateLang}
      aria-label={switchLanguageLabel}
      class="text-muted hover:text-text uppercase font-mono text-xs"
    >
      {alternateLang}
    </a>
    <a href="https://demo.wiregrid.fr" target="_blank" rel="noopener" class="btn btn-primary text-center">
      {t(lang, 'nav.demo')}
    </a>
  </nav>
</header>

<script is:inline define:vars={{ openLabel: t(lang, 'a11y.open_menu'), closeLabel: t(lang, 'a11y.close_menu') }}>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    const setOpen = (open) => {
      menu.classList.toggle('hidden', !open);
      menu.classList.toggle('flex', open);
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? closeLabel : openLabel);
    };
    btn.addEventListener('click', () => setOpen(menu.classList.contains('hidden')));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) setOpen(false);
    });
  }
</script>
