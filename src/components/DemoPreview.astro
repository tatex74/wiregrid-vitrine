---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-20 px-6">
  <div class="mx-auto max-w-6xl text-center">
    <h2 class="text-3xl md:text-4xl font-semibold mb-4">{t(lang, 'demo.title')}</h2>
    <p class="text-muted text-lg mb-10 max-w-xl mx-auto">{t(lang, 'demo.desc')}</p>

    <!-- Placeholder for screenshot/video -->
    <div class="mx-auto max-w-4xl rounded-md border border-border bg-surface overflow-hidden">
      <div class="aspect-video flex items-center justify-center bg-surface-hi">
        <div class="text-center">
          <svg class="w-16 h-16 text-brand mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 0 1 0 .656l-5.603 3.113a.375.375 0 0 1-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112Z"/>
          </svg>
          <p class="text-muted text-sm font-mono">screenshot / demo video</p>
        </div>
      </div>
    </div>

    <div class="mt-8">
      <a href="https://demo.wiregrid.fr" target="_blank" rel="noopener" class="btn btn-primary btn-lg">
        {t(lang, 'demo.cta')}
      </a>
    </div>
  </div>
</section>
