---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const rows = [
  { criterion: 'tag_pricing',     wg: 'no',     ng: 'yes_5',  ig: 'yes_lite', ec: 'yes_pro' },
  { criterion: 'data_storage',    wg: 'pg',     ng: 'proprio', ig: 'proprio', ec: 'proprio' },
  { criterion: 'bi_connector',    wg: 'native', ng: 'export',  ig: 'odbc',     ec: 'export'  },
  { criterion: 'self_host',       wg: 'docker', ng: 'jvm',     ig: 'jvm',     ec: 'cloud'    },
  { criterion: 'config_versioning', wg: 'git',  ng: 'manual',  ig: 'manual',  ec: 'manual'   },
  { criterion: 'web_native',      wg: 'yes',    ng: 'partial', ig: 'yes',     ec: 'yes'      },
  { criterion: 'protocols',       wg: 'p3',     ng: 'p20',     ig: 'p20',     ec: 'p15'      },
  { criterion: 'startup_cost',    wg: 'free',   ng: '5k',      ig: '4k',      ec: 'quote'    },
];

const cellClass = (val: string) => {
  if (['no', 'pg', 'native', 'docker', 'git', 'yes', 'free'].includes(val)) return 'text-brand';
  if (['partial', 'odbc'].includes(val)) return 'text-warning';
  return 'text-muted';
};
---

<section id="comparison" class="section">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-8">
      <div class="lg:col-span-5">
        <div class="section-eyebrow">02 · Comparaison</div>
        <h2 class="section-title">{t(lang, 'comparison.title')}</h2>
      </div>
      <p class="lg:col-span-7 section-lede mt-2 lg:mt-8">{t(lang, 'comparison.subtitle')}</p>
    </div>

    <div class="border border-border rounded-md overflow-hidden bg-surface">
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm font-mono min-w-[680px]">
          <thead class="bg-surface-hi">
            <tr>
              <th class="text-left py-2.5 pl-4 pr-3 text-[10px] uppercase tracking-[0.1em] text-muted font-medium border-b border-border">
                {t(lang, 'comparison.col.criterion')}
              </th>
              <th class="text-left py-2.5 px-3 text-[11px] uppercase tracking-[0.05em] text-brand font-semibold border-b border-border bg-brand/5">wiregrid</th>
              <th class="text-left py-2.5 px-3 text-[11px] uppercase tracking-[0.05em] text-muted-strong font-medium border-b border-border">niagara n4</th>
              <th class="text-left py-2.5 px-3 text-[11px] uppercase tracking-[0.05em] text-muted-strong font-medium border-b border-border">ignition</th>
              <th class="text-left py-2.5 px-3 pr-4 text-[11px] uppercase tracking-[0.05em] text-muted-strong font-medium border-b border-border">ecostruxure</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row, i) => (
              <tr class={i % 2 === 0 ? '' : 'bg-bg/30'}>
                <th scope="row" class="text-left py-2 pl-4 pr-3 font-sans font-medium text-text text-[13px] border-b border-border/50 last:border-0">
                  {t(lang, `comparison.criterion.${row.criterion}`)}
                </th>
                <td class={`py-2 px-3 ${cellClass(row.wg)} bg-brand/[0.04] border-b border-border/50 last:border-0`}>{t(lang, `comparison.value.${row.wg}`)}</td>
                <td class={`py-2 px-3 ${cellClass(row.ng)} border-b border-border/50 last:border-0`}>{t(lang, `comparison.value.${row.ng}`)}</td>
                <td class={`py-2 px-3 ${cellClass(row.ig)} border-b border-border/50 last:border-0`}>{t(lang, `comparison.value.${row.ig}`)}</td>
                <td class={`py-2 px-3 pr-4 ${cellClass(row.ec)} border-b border-border/50 last:border-0`}>{t(lang, `comparison.value.${row.ec}`)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <p class="mt-4 text-[11px] font-mono text-muted">{t(lang, 'comparison.disclaimer')}</p>
  </div>
</section>
