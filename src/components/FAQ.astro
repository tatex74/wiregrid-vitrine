---
import { t, type Lang } from '../i18n';
import { FAQ_KEYS } from '../i18n/faq-keys';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="faq" class="px-6 py-24 md:py-32 border-t border-border/60" style="background:var(--color-bg-alt);">
  <div class="mx-auto max-w-3xl">
    <div class="text-center mb-14">
      <div class="section-eyebrow justify-center">{t(lang, 'faq.eyebrow')}</div>
      <h2 class="section-title">{t(lang, 'faq.title')}</h2>
      <p class="section-lede mx-auto">{t(lang, 'faq.subtitle')}</p>
    </div>

    <div class="bg-surface rounded-lg border border-border divide-y divide-border overflow-hidden">
      {FAQ_KEYS.map((key) => (
        <details id={`faq-${key}`} class="group">
          <summary class="flex items-start gap-4 cursor-pointer list-none px-6 py-5 hover:bg-bg-alt/40 transition-colors">
            <svg
              class="w-4 h-4 mt-[3px] shrink-0 text-muted-strong group-open:text-brand group-open:rotate-45 transition-all"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <line x1="8" y1="3" x2="8" y2="13"/>
              <line x1="3" y1="8" x2="13" y2="8"/>
            </svg>
            <span class="flex-1 font-medium text-text text-[16px]">{t(lang, `faq.${key}.q`)}</span>
          </summary>
          <div class="px-6 pb-5 pl-14 text-[15px] text-muted-strong leading-[1.65]">
            <div set:html={t(lang, `faq.${key}.a_html`)} />
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  // Auto-open a FAQ <details> when the URL hash matches its id.
  // Used by deep-links like /<lang>/#faq-company_disappears so callers
  // can land directly on the answer without an extra click.
  (function () {
    function applyHash() {
      var hash = window.location.hash;
      if (!hash || hash.indexOf('#faq-') !== 0) return;
      var el = document.getElementById(hash.slice(1));
      if (el && el.tagName === 'DETAILS') {
        el.open = true;
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
    applyHash();
    window.addEventListener('hashchange', applyHash);
  })();
</script>
