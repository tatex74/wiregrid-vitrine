---
import { t, type Lang } from '../i18n';
import { FAQ_KEYS } from '../i18n/faq-keys';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="faq" class="section">
  <div class="mx-auto max-w-3xl">
    <div class="mb-8">
      <div class="section-eyebrow">07 · FAQ</div>
      <h2 class="section-title">{t(lang, 'faq.title')}</h2>
      <p class="section-lede">{t(lang, 'faq.subtitle')}</p>
    </div>

    <div class="border border-border rounded-md divide-y divide-border bg-surface">
      {FAQ_KEYS.map((key) => (
        <details class="group">
          <summary class="flex items-start gap-3 cursor-pointer list-none px-5 py-3.5 hover:bg-surface-hi/40 transition-colors">
            <span class="font-mono text-brand text-[11px] mt-1 shrink-0 group-open:rotate-90 transition-transform inline-block">▸</span>
            <span class="flex-1 font-medium text-text text-sm">{t(lang, `faq.${key}.q`)}</span>
          </summary>
          <div class="px-5 pb-4 pl-12 text-sm text-muted-strong leading-relaxed">
            <div set:html={t(lang, `faq.${key}.a_html`)} />
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
