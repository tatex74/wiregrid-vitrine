---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const tiers = [
  {
    id: 'free',
    highlight: false,
    cta_href: 'https://demo.wiregrid.fr',
    cta_external: true,
    features: [
      'feature.points_50',
      'feature.protocols_modbus',
      'feature.historian_7d',
      'feature.alarms',
      'feature.api_open',
      'feature.support_docs',
    ],
  },
  {
    id: 'pro',
    highlight: true,
    cta_href: 'mailto:contact@wiregrid.fr?subject=Wiregrid%20Production',
    cta_external: false,
    features: [
      'feature.points_unlimited',
      'feature.protocols_all',
      'feature.historian_unlimited',
      'feature.alarms_notifications',
      'feature.api_open',
      'feature.support_dedicated',
      'feature.priority_roadmap',
    ],
  },
];
---

<section id="pricing" class="section">
  <div class="mx-auto max-w-5xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-10">
      <div class="lg:col-span-5">
        <div class="section-eyebrow">06 · Tarifs</div>
        <h2 class="section-title">{t(lang, 'pricing.title')}</h2>
      </div>
      <p class="lg:col-span-7 section-lede mt-2 lg:mt-8">{t(lang, 'pricing.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {tiers.map((tier) => (
        <div class={`rounded-md p-6 bg-surface ${tier.highlight ? 'border border-brand/40' : 'border border-border'}`}>
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="text-xl font-semibold tracking-tight">{t(lang, `pricing.${tier.id}.name`)}</h3>
            {tier.highlight && (
              <span class="text-[10px] font-mono uppercase tracking-wider text-brand bg-brand/10 px-1.5 py-0.5 rounded-sm border border-brand/30">
                {t(lang, 'pricing.recommended')}
              </span>
            )}
          </div>
          <p class="text-muted text-sm leading-relaxed">{t(lang, `pricing.${tier.id}.tagline`)}</p>

          <div class="mt-6 pb-5 border-b border-border">
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-semibold text-text tabular-nums">{t(lang, `pricing.${tier.id}.price`)}</span>
              <span class="text-sm font-mono text-muted">{t(lang, `pricing.${tier.id}.period`)}</span>
            </div>
            <p class="text-xs text-muted mt-1.5 font-mono">{t(lang, `pricing.${tier.id}.price_note`)}</p>
            {tier.id === 'pro' && (
              <p class="text-[11px] text-brand mt-2 font-mono leading-relaxed" set:html={t(lang, 'pricing.pro.anchor_html')} />
            )}
          </div>

          <ul class="mt-5 space-y-2 text-sm">
            {tier.features.map((feat) => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 mt-[2px] text-brand shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" aria-hidden="true">
                  <polyline points="3 8 7 12 13 4" stroke-linejoin="miter"/>
                </svg>
                <span class="text-muted-strong" set:html={t(lang, `pricing.${feat}`)} />
              </li>
            ))}
          </ul>

          <div class="mt-6">
            <a
              href={tier.cta_href}
              {...(tier.cta_external ? { target: '_blank', rel: 'noopener' } : {})}
              class={`btn ${tier.highlight ? 'btn-primary' : 'btn-outline'} w-full justify-center`}
            >
              {t(lang, `pricing.${tier.id}.cta`)}
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-6 text-[11px] font-mono text-muted">{t(lang, 'pricing.footnote')}</p>
  </div>
</section>
