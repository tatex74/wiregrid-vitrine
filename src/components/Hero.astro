---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="pt-32 pb-16 px-6">
  <div class="mx-auto max-w-4xl text-center">
    <div class="inline-block mb-6 px-4 py-1.5 rounded-full border border-brand/30 bg-brand/5 text-brand text-xs font-medium tracking-wide uppercase">
      {lang === 'fr' ? 'Plateforme de supervision industrielle' : 'Industrial supervision platform'}
    </div>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-tight">
      {t(lang, 'hero.title')}
    </h1>

    <p class="mt-6 text-lg md:text-xl text-muted-strong max-w-2xl mx-auto leading-relaxed">
      {t(lang, 'hero.subtitle')}
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="https://demo.wiregrid.fr" target="_blank" rel="noopener" class="btn btn-primary btn-lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z"/></svg>
        {t(lang, 'hero.cta_demo')}
      </a>
      <a href="https://demo.wiregrid.fr" target="_blank" rel="noopener" class="btn btn-outline btn-lg">
        {t(lang, 'hero.cta_download')}
      </a>
    </div>

    <!-- Screenshot mockup -->
    <div class="mt-16 mx-auto max-w-4xl rounded-md border border-border overflow-hidden shadow-2xl shadow-brand/5">
      <div class="bg-surface-hi px-4 py-2.5 border-b border-border flex items-center gap-2">
        <div class="flex gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full bg-error/60"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-warning/60"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-success/60"></span>
        </div>
        <span class="text-xs text-muted font-mono ml-2">wiregrid — supervision</span>
      </div>
      <div class="aspect-video bg-surface flex items-center justify-center">
        <div class="text-center px-8">
          <svg class="w-12 h-12 text-brand/40 mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z"/>
          </svg>
          <p class="text-muted text-sm">{lang === 'fr' ? 'Aperçu de l\'interface — disponible prochainement' : 'Interface preview — coming soon'}</p>
        </div>
      </div>
    </div>
  </div>
</section>
