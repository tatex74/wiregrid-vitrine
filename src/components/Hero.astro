---
import { t, type Lang } from '../i18n';
import AppPreview from './AppPreview.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="pt-28 pb-12 px-6">
  <div class="mx-auto max-w-6xl grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
    <div class="lg:col-span-5">
      <div class="section-eyebrow flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-brand"></span>
        SCADA · Modbus / OPC-UA / BACnet
      </div>

      <h1 class="mt-4 text-4xl md:text-[2.75rem] lg:text-5xl font-semibold tracking-[-0.025em] leading-[1.05]">
        <span set:html={t(lang, 'hero.title_html')} />
      </h1>

      <p class="mt-5 text-base md:text-lg text-muted-strong leading-relaxed max-w-lg">
        <span set:html={t(lang, 'hero.subtitle_html')} />
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href="https://demo.wiregrid.fr" target="_blank" rel="noopener" class="btn btn-primary btn-lg">
          {t(lang, 'hero.cta_demo')}
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M6 3l5 5-5 5" stroke-linecap="square"/>
          </svg>
        </a>
        <button
          type="button"
          class="btn btn-shell btn-lg"
          data-copy="docker compose up -d"
          aria-label={t(lang, 'hero.cta_shell_aria')}
        >
          docker compose up -d
        </button>
      </div>

      <p class="mt-3 text-xs text-muted">
        <span set:html={t(lang, 'hero.cta_note_html')} />
      </p>
    </div>

    <div class="lg:col-span-7">
      <AppPreview lang={lang} compact />
      <p class="mt-2 text-[11px] font-mono text-muted text-right">
        <span class="opacity-60">↑</span> {t(lang, 'hero.preview_label')}
      </p>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('button[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy') || '';
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = 'copied';
        setTimeout(() => { btn.textContent = original; }, 1400);
      } catch {}
    });
  });
</script>
