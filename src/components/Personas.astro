---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const personas = ['p1', 'p2', 'p3', 'p4'] as const;
---

<section id="personas" class="px-6 py-24 md:py-32 border-t border-border/60">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="section-eyebrow justify-center">{t(lang, 'personas.eyebrow')}</div>
      <h2 class="section-title">{t(lang, 'personas.title')}</h2>
      <p class="section-lede mx-auto">{t(lang, 'personas.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {personas.map((id) => (
        <article class="bg-surface rounded-lg border border-border p-7 flex flex-col">
          <h3 class="font-semibold text-text text-[17px] tracking-tight mb-3">
            {t(lang, `personas.${id}.role`)}
          </h3>
          <p class="text-[14px] text-muted-strong leading-relaxed mb-4">
            {t(lang, `personas.${id}.context`)}
          </p>

          <div class="mt-auto pt-4 border-t border-border/70 space-y-3">
            <div>
              <span class="block text-[10px] font-mono uppercase tracking-wider text-muted mb-1">Le pain</span>
              <p class="text-[13.5px] text-text leading-relaxed">{t(lang, `personas.${id}.pain`)}</p>
            </div>
            <div>
              <span class="block text-[10px] font-mono uppercase tracking-wider text-brand mb-1">Wiregrid pour vous</span>
              <p class="text-[13.5px] text-text leading-relaxed">{t(lang, `personas.${id}.fit`)}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
