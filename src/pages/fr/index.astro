---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Personas from '../../components/Personas.astro';
import Features from '../../components/Features.astro';
import BIPreview from '../../components/BIPreview.astro';
import Lifecycle from '../../components/Lifecycle.astro';
import Sovereignty from '../../components/Sovereignty.astro';
import Pricing from '../../components/Pricing.astro';
import FAQ from '../../components/FAQ.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const lang = 'fr' as const;
---

<Base
  lang={lang}
  title="Wiregrid · Supervision SCADA, forfait fixe, données chez vous"
  description="Supervision SCADA web qui lit vos automates Modbus TCP, OPC-UA et BACnet/IP, historise, alerte. Données accessibles en PostgreSQL standard via ODBC pour Power BI, Grafana ou Excel. Forfait Standard 990 €/an par site, tous les points inclus, essai 7 jours gratuit."
>
  <Hero lang={lang} />
  <Personas lang={lang} />
  <Features lang={lang} />
  <BIPreview lang={lang} />
  <Lifecycle lang={lang} />
  <Sovereignty lang={lang} />
  <Pricing lang={lang} />
  <FAQ lang={lang} />
  <FinalCTA lang={lang} />
</Base>
